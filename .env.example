# Session encryption key — generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Bcrypt hash of your login password — generate with:
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword',10))"
# The hash must start with $2b$10$ or $2a$10$
AUTH_PASSWORD_HASH=

NODE_ENV=development

# Set to "true" to skip authentication entirely (safe for local-only deployments)
# AUTH_DISABLED=true
